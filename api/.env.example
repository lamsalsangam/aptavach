# Aptavach API — copy to `.env` and adjust. Every key is prefixed APTAVACH_.

# --- App ---
APTAVACH_ENVIRONMENT=development
# JSON array of allowed frontend origins
APTAVACH_CORS_ORIGINS=["http://localhost:5173"]

# --- Ollama (local, free by default) ---
APTAVACH_OLLAMA_BASE_URL=http://localhost:11434
APTAVACH_REQUEST_TIMEOUT=120

# --- LLM (generation) ---
APTAVACH_LLM_PROVIDER=ollama
APTAVACH_LLM_MODEL=qwen2.5:7b
APTAVACH_CONTEXT_WINDOW=8192
# Cloud fallback later: set the provider + key, and add the adapter in providers/llm.py
# APTAVACH_LLM_PROVIDER=openai
# APTAVACH_LLM_API_KEY=sk-...

# --- Embeddings ---
APTAVACH_EMBED_PROVIDER=ollama
APTAVACH_EMBED_MODEL=bge-m3

# --- Vector store (Qdrant) ---
APTAVACH_QDRANT_LOCATION=local
APTAVACH_QDRANT_PATH=storage/qdrant
APTAVACH_COLLECTION_NAME=aptavach
# Move to Qdrant Cloud/server later — no code changes:
# APTAVACH_QDRANT_LOCATION=server
# APTAVACH_QDRANT_URL=https://xxxx.qdrant.io
# APTAVACH_QDRANT_API_KEY=...

# --- Retrieval / chunking ---
APTAVACH_CHUNK_SIZE=512
APTAVACH_CHUNK_OVERLAP=80
APTAVACH_SIMILARITY_TOP_K=5
